# ============================================================
# SLIP A TIP — Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/slipatip?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/slipatip?schema=public"

# --- Authentication (REQUIRED — app will refuse to start without this) ---
# Generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# --- Application URL ---
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# --- Cloudflare R2 (Document Storage) ---
# Account ID from Cloudflare dashboard
R2_ACCOUNT_ID="e02c769a6506c70f402644285cd691b8"
# Use the Account API Token Access Key (not User API Token)
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="slipatip-documents"
# S3 endpoint — do NOT include bucket name here
R2_ENDPOINT="https://e02c769a6506c70f402644285cd691b8.r2.cloudflarestorage.com"

# --- Email (Resend) ---
RESEND_API_KEY="re_..."

# --- Cron Job Protection (REQUIRED if using cron endpoints) ---
# Generate with: openssl rand -hex 32
CRON_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32"

# --- Sentry (Error Monitoring) ---
SENTRY_DSN="https://..."
NEXT_PUBLIC_SENTRY_DSN="https://..."
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# --- Payout Provider ---
# "mock" = logs to console (dev/test), "stitch" = Stitch Payouts API (EFT, R2 flat fee)
PAYOUT_PROVIDER="stitch"

# --- Stitch Payouts (EFT withdrawals — separate OAuth client from pay-in) ---
# If you use the same Stitch client for both pay-in and payouts, leave these blank
# and STITCH_CLIENT_ID / STITCH_CLIENT_SECRET will be used as fallback.
STITCH_PAYOUT_CLIENT_ID=""
STITCH_PAYOUT_CLIENT_SECRET=""

# --- OTT Mobile (OTT Voucher withdrawals) ---
# Obtain credentials from OTT Mobile partner portal
OTT_BASE_URL="https://test-api.ott-mobile.com"
OTT_USERNAME=""
OTT_PASSWORD=""
OTT_VENDOR_ID="11"
OTT_PIN=""
# Cached API key — rotated automatically via GetAPIKey endpoint
OTT_API_KEY=""

# --- Redis (Rate limiting + OTP store) ---
# Format: redis://:<password>@<host>:<port>  (use rediss:// for TLS)
REDIS_URL="redis://:your_redis_password@redis-17458.c62.us-east-1-4.ec2.cloud.redislabs.com:17458"

# --- SMS Provider — Demakatso (OTP phone verification) ---
SMS_API_URL="https://api.demakatso.com:8080/send"
SMS_USERNAME="your_demakatso_username"
SMS_PASSWORD="your_demakatso_password"

# --- Stitch Money (Instant EFT / Pay-by-bank — pay-ins) ---
STITCH_CLIENT_ID="test-..."
STITCH_CLIENT_SECRET="your_stitch_client_secret"

# --- WhatsApp Cloud API (Meta Business Platform) ---
# Phone Number ID from Meta > WhatsApp > API Setup (e.g. "123456789012345")
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_number_id"
# Long-lived System User access token from Meta Business Manager
WHATSAPP_ACCESS_TOKEN="your_whatsapp_access_token"
# Webhook verify token — any secret string you choose, set same value in Meta App Dashboard
WHATSAPP_VERIFY_TOKEN="your_whatsapp_webhook_verify_token"
# (Optional) Approved template name for follow-up reminder sent outside the 24h window
# Create template in Meta Business Manager > WhatsApp > Message Templates
# Template must accept 3 body params: {{1}}=workerFirstName, {{2}}=amount, {{3}}=paymentUrl
WHATSAPP_FOLLOWUP_TEMPLATE_NAME=""
# The WhatsApp Business number customers message — E.164 without + (e.g. "27821234567")
# This is encoded into every worker's QR code as: https://wa.me/27821234567?text=TIP+[qrCode]
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER="27XXXXXXXXX"

# --- Firebase (Android Push Notifications via FCM HTTP v1 API) ---
# Download the service account JSON from Firebase Console > Project Settings > Service Accounts
# Paste the entire JSON as a single-line string (escape newlines in private_key with \n)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# --- Seed (Development ONLY — never set in production) ---
SEED_ADMIN_EMAIL="admin@slipatip.co.za"
SEED_ADMIN_PASSWORD="!!AnCam123"
SEED_WORKER_PASSWORD="!!AnCam123"

